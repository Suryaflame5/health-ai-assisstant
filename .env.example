# ============================================
# Autonomous AI Desktop Assistant — Environment
# ============================================

# LLM Provider
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# Local LLM (Ollama fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_assistant
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/ai_assistant

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_HOST=localhost
CHROMA_PORT=8100

# Voice
WHISPER_MODEL=base
TTS_PROVIDER=edge-tts

# Security
SECRET_KEY=change-this-to-a-random-secret-key
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# App Settings
LOG_LEVEL=INFO
CONFIRM_DESTRUCTIVE_ACTIONS=true
MAX_AUTOMATION_STEPS=50
SCREENSHOT_DIR=./screenshots
